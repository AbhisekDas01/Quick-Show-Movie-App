# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net

# Clerk (server-side)
CLERK_SECRET_KEY=sk_live_...
# Clerk (client-side, safe to expose)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk redirect URLs (configure as needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# TMDB
TMDB_API_KEY=eyJ...
# Accessible in both server and client components
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# Razorpay (server-side secrets)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_SECRET_KEY=...
# Razorpay (client-side, safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY=rzp_live_...
NEXT_PUBLIC_RAZORPAY_URL=https://checkout.razorpay.com/v1/checkout.js

# Currency symbol
NEXT_PUBLIC_CURRENCY=₹

# Email (Brevo SMTP)
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=

# Client URL (used in notification emails)
CLIENT_BASE_URL=http://localhost:3000
